{:paths ["src"]
 ;; west checks this repo out as a sibling of orgs/kotoba-lang/{vrm,character}
 ;; (orgs/kotoba-lang/kami-app-character-creator/), so relative :local/root resolves.
 :deps {io.github.kotoba-lang/vrm {:local/root "../vrm"}
        io.github.kotoba-lang/character {:local/root "../character"}}
 :aliases {:test {:extra-paths ["test"]
                  :extra-deps {io.github.cognitect-labs/test-runner
                               {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
                  :main-opts ["-m" "cognitect.test-runner"]}
           ;; Phase 2 (ADR-2607031200) preview-demo.html build only. `../webgpu`
           ;; is `kotoba.lang/webgpu`'s `kami.webgpu.mesh` (skin/morph executor) —
           ;; a dev-only dep, not part of the pipeline's :deps (which stays
           ;; browser/JVM-portable, no GPU/cljs dependency).
           :cljs {:extra-paths ["dev"]
                  :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}
                               io.github.kotoba-lang/webgpu {:local/root "../webgpu"}}
                  :main-opts ["-m" "cljs.main" "-co" "dev/build.edn" "-c" "character-creator.preview-demo"]}
           ;; /loop maturity pass — the real interactive character-creation screen
           ;; (`app.html`/`character-creator.app`), same dev-only shape as `:cljs`
           ;; above plus `kami-engine-app-sdk` (renamed from `kami-ui-sdk`, see
           ;; com-junkawasaki/root ADR-2607041500; namespace stays
           ;; `kami-ui-sdk.widgets`'s real DOM slider/color-swatch/carousel).
           :cljs-app {:extra-paths ["dev"]
                      :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}
                                   io.github.kotoba-lang/webgpu {:local/root "../webgpu"}
                                   io.github.kotoba-lang/kami-engine-app-sdk {:local/root "../kami-engine-app-sdk"}}
                      :main-opts ["-m" "cljs.main" "-co" "dev/app-build.edn" "-c" "character-creator.app"]}
           ;; /loop maturity pass — procedural material patterns (kami.webgpu.mesh's
           ;; new color_b/pattern_kind/pattern_params uniform): a flat-vs-gradient
           ;; side-by-side proof for pattern-demo.html, same dev-only shape as :cljs.
           :cljs-pattern {:extra-paths ["dev"]
                          :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}
                                       io.github.kotoba-lang/webgpu {:local/root "../webgpu"}}
                          :main-opts ["-m" "cljs.main" "-co" "dev/pattern-build.edn" "-c" "character-creator.pattern-demo"]}}}
